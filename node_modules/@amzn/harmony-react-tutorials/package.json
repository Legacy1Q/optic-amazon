{
  "name": "@amzn/harmony-react-tutorials",
  "version": "3.0.0",
  "description": "A set of React components intended for use in training users on how to create and deploy apps in Harmony",
  "author": "bryantdb@",
  "main": "dist/harmony-tutorials.cjs.js",
  "module": "dist/harmony-tutorials.esm.js",
  "unpkg": "dist/harmony-tutorials.umd.js",
  "style": "dist/harmony-tutorials.css",
  "exports": {
    ".": {
      "import": "./dist/harmony-tutorials.esm.js",
      "require": "./dist/harmony-tutorials.cjs.js",
      "unpkg": "./dist/harmony-tutorials.umd.js"
    },
    "./style": "./dist/harmony-tutorials.css",
    "./dist/harmony-tutorials.css": "./dist/harmony-tutorials.css"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "vite build",
    "prepublish": "rm -rf ./dist && npm run build",
    "prepare": "npm run build",
    "dev": "vite build --watch"
  },
  "license": "ISC",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^4.4.0"
  },
  "dependencies": {
    "@amzn/sentry-fetch": "^2.1.3",
    "bootstrap": "^4.3.1",
    "react-bootstrap": "^1.0.0-beta.12"
  }
}
