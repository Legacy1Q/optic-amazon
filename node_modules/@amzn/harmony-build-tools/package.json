{
  "name": "@amzn/harmony-build-tools",
  "version": "0.1.2",
  "type": "module",
  "license": "UNLICENSED",
  "repository": "ssh://git.amazon.com/pkg/HarmonyBuildTools",
  "homepage": "https://code.amazon.com/packages/HarmonyBuildTools",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist && rm -rf node_modules",
    "build": "vite build",
    "watch": "vite build --watch",
    "dev": "vite",
    "prepublishOnly": "npm run format:check && npm run build && npm run test",
    "test": "vitest run --coverage",
    "posttest": "generate-coverage-data --language typescript",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite-plugins": {
      "types": "./dist/vite/plugin/index.d.ts",
      "import": "./dist/vite/plugin/index.js",
      "require": "./dist/vite/plugin/index.cjs"
    }
  },
  "files": [
    "dist/",
    "!**/__tests__/**"
  ],
  "npm-pretty-much": {
    "runTest": "never"
  },
  "devDependencies": {
    "@amzn/brazil": "^2.0.6",
    "@tsconfig/node20": "^20.1.5",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^1.3.1",
    "prettier": "^3.2.5",
    "typescript": "~5.4.5",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1"
  },
  "peerDependencies": {
    "vite": "^5.4.21"
  }
}
