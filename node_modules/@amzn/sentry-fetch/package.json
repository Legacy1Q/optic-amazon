{
  "name": "@amzn/sentry-fetch",
  "version": "2.1.9",
  "license": "UNLICENSED",
  "main": "es5/index.js",
  "module": "es6/index.js",
  "types": "es6/index.d.ts",
  "files": [
    "es5/",
    "es6/"
  ],
  "npm-pretty-much": {
    "publishLibCommonJs": true
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run build:es5 && npm run build:es6",
    "build:es5": "tsc --target 'ES5' --module 'commonjs' --outDir es5",
    "build:es6": "tsc --target 'ES6' --module 'es6' --outDir es6",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^25.0.0",
    "@types/node": "^11.0.0",
    "jest": "^25.0.0",
    "jest-fetch-mock": "^3.0.0",
    "ts-jest": "^25.0.0",
    "typescript": "^3.0.0",
    "webpack": "^4.0.0",
    "webpack-cli": "^3.0.0"
  },
  "dependencies": {}
}
