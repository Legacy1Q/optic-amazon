{
  "name": "@amzn/harmony-build-scripts",
  "version": "0.1.4",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "ssh://git.amazon.com/pkg/HarmonyBuildScripts"
  },
  "homepage": "https://code.amazon.com/packages/HarmonyBuildScripts",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "publish-harmony-app": "bin/publish-harmony-app.js"
  },
  "scripts": {
    "clean": "rm -rf dist && rm -rf node_modules",
    "prebuild": "rm -rf dist",
    "prettier": "prettier --check ./src --check ./bin --ignore-path .gitignore",
    "prettier-fix": "prettier --write ./src --check ./bin --ignore-path .gitignore",
    "build": "npm run prettier && tsc",
    "watch": "tsc -w",
    "test": "",
    "posttest": "generate-coverage-data --language typescript",
    "tsc": "tsc -w",
    "build-link": "npm run build && npm link",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "!**/__tests__/**"
  ],
  "npm-pretty-much": {
    "runTest": "never"
  },
  "devDependencies": {
    "@amzn/brazil": "^2.0.6",
    "@tsconfig/node18": "^18.2.4",
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.10",
    "esbuild": "^0.24.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.4",
    "tsx": "^4.19.2",
    "typescript": "~5.4.5"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "getopts": "^2.3.0",
    "ion-js": "^5.2.1"
  }
}