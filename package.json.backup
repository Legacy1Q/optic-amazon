{
  "name": "@amzn/optic-amazon",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "npm run dev",
    "test": "vitest",
    "build-harmony-app": "build-harmony --templateName react",
    "prepublishOnly": "cross-env BUILD_PATH=build/app npm run build && publish-harmony-app --apply-legacy-cleaning"
  },
  "dependencies": {
    "@amzn/harmony-build-scripts": "^0.1.4",
    "@amzn/harmony-react-tutorials": "^3.0.0",
    "@amzn/harmony-types": "^latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@amzn/harmony-build-tools": "^0.1.1",
    "@amzn/harmony-types": "^1.0.47",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
